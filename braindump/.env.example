# Where the Obsidian vault lives. In real use this points at your synced
# Obsidian/Syncthing folder, NOT into this repo. Defaults to ./vault for dev.
VAULT_PATH=./vault

# Derived index. The index is disposable, so the engine is a config detail.
# Default: local SQLite (zero infra). Swap to Postgres later without changing
# the vault — that swap is the whole point of a disposable index.
INDEX_URL=sqlite:///index.db
# INDEX_URL=postgresql+psycopg://user:pass@host/db   # later, with pgvector

# Reasoning engine (Claude) — not wired yet, here so the shape exists.
# ANTHROPIC_API_KEY=
