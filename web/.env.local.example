# --- contact form (EmailJS) ---
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# --- talkerinos blog (Supabase, server-side only) ---
# Supabase dashboard -> Settings -> API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- schema management (drizzle-kit push; local only, not needed on Vercel) ---
# Supabase dashboard -> Connect -> ORMs -> Drizzle: the postgres:// URL with password
DATABASE_URL=

# admin key for write endpoints; same value you type into the admin UI
BLOG_API_KEY=

# --- admin AI editor ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- admin sign-in (password -> signed session cookie) ---
# openssl rand -base64 32
AUTH_SECRET=
# the password you type into the navbar to unlock editing
ADMIN_PASSWORD=

# --- synced calendars (admin-only overlay) ---
# secret ICS urls, comma-separated (Google: calendar settings -> Secret address
# in iCal format; iCloud: public calendar link, webcal:// -> https://)
CALENDAR_FEEDS=
CALENDAR_TZ=America/New_York
